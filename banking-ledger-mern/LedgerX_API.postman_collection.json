{
  "info": {
    "name": "LedgerX Banking API",
    "description": "Complete API collection for the LedgerX Banking Ledger System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token",   "value": "" },
    { "key": "accountId",   "value": "" },
    { "key": "toAccountId", "value": "" },
    { "key": "transactionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Jane@12345\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@bank.com\",\n  \"password\": \"Admin@12345\"\n}" }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Alice@12345\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Account",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('accountId', pm.response.json().account._id);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/accounts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accountType\": \"checking\",\n  \"currency\": \"USD\",\n  \"description\": \"My main checking account\"\n}" }
          }
        },
        {
          "name": "Get Single Account",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts/{{accountId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Deposit",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('transactionId', pm.response.json().transaction._id);",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions/deposit/{{accountId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 5000.00,\n  \"description\": \"Initial deposit\"\n}" }
          }
        },
        {
          "name": "Withdraw",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions/withdraw/{{accountId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 200.00,\n  \"description\": \"ATM withdrawal\"\n}" }
          }
        },
        {
          "name": "Transfer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions/transfer/{{accountId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"toAccountId\": \"{{toAccountId}}\",\n  \"amount\": 500.00,\n  \"description\": \"Rent payment\"\n}" }
          }
        },
        {
          "name": "Transaction History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions/history/{{accountId}}?page=1&limit=10&type=&status=completed",
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" },
                { "key": "type",   "value": "" },
                { "key": "status", "value": "completed" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "startDate", "value": "", "disabled": true },
                { "key": "endDate",   "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Transaction Detail + Ledger",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions/detail/{{transactionId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users?page=1&limit=20",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/users/USER_ID_HERE/toggle-status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/audit-logs?page=1&limit=20",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
